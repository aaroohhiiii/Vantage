# ============================================
# SUPABASE
# Get these from: supabase.com → your project
# → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# ANTHROPIC
# Get from: console.anthropic.com → API Keys
# Apply for free credits at the same place
# ============================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# RESEND (email sending)
# Get from: resend.com → API Keys
# Free tier: 3,000 emails/month
# ============================================
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# UPSTASH REDIS (rate limiting)
# Get from: console.upstash.com → your database
# → REST API section
# ============================================
UPSTASH_REDIS_REST_URL="https://sharing-dingo.upstash.io"
UPSTASH_REDIS_REST_TOKEN="token"

# ============================================
# APP CONFIG
# Change to your actual Vercel URL after deploy
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000